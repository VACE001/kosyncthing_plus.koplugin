#!/bin/sh
# start-syncthing — unified launcher for the Syncthing daemon under KOReader.
#
# Usage: start-syncthing <home_dir> <port> <koreader_dir> [resource] [network] [binary_name] [config_dirname] [legacy_version]
#
#   resource     : low (default) | normal
#   network      : lan (default) | global
#   binary_name  : syncthing (default) | syncthing-legacy
#       The filename of the binary inside the plugin folder.  Passing
#       "syncthing-legacy" activates legacy mode without any other change
#       to the script logic — all safety features, memory tuning, and
#       double-start guard are inherited automatically.
#   config_dirname : syncthing (default) | syncthing-legacy
#       The subdirectory inside $KOREADER_DIR/settings/ used for config,
#       logs, and device-id cache.  Must match the binary_name so each
#       binary has its own isolated state directory.
#   legacy_version : empty (default) | v1.27.12 | v1.2.2
#       The selected legacy Syncthing version, passed by st_process.lua.
#       Only "v1.2.2" changes script behaviour: that release predates the
#       `serve`/`generate` subcommand interface and the --config/--data
#       split (both introduced around v1.7.0), so it needs the historical
#       single-dash command line.  Empty and "v1.27.12" use the modern CLI.
#
# DO NOT use set -e. Handle errors manually so we can emit clear messages.

# ---------------------------------------------------------------------------
# Cleanup trap — registered early so every exit path is covered.
# The body only touches $pid_file; if that variable is still empty on an
# early exit, [ -f "" ] is false and the body is a safe no-op.
# ---------------------------------------------------------------------------
pid_file="/tmp/syncthing_koreader.pid"
written_pid="no"
cleanup() {
    if [ "$written_pid" = "no" ] && [ -f "$pid_file" ]; then
        rm -f "$pid_file"
    fi
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# Argument validation
# ---------------------------------------------------------------------------
if [ $# -lt 3 ]; then
    echo "Usage: $0 <home_dir> <port> <koreader_dir> [resource] [network]" >&2
    echo "At least the first three arguments are required." >&2
    exit 2
fi

home_dir="$1"
port="$2"
KOREADER_DIR="$3"
resource="${4:-low}"
network="${5:-lan}"
# Args 6, 7 and 8 are optional and default to standard mode.
# st_process.lua sets them explicitly when launching in legacy mode.
binary_name="${6:-syncthing}"
config_dirname="${7:-syncthing}"
legacy_version="${8:-}"
# Arg 9 (optional): the database directory chosen by st_utils.getDataDir().
# On an affected Kindle this is a persistent ext path off the hard_remove
# FUSE mount; otherwise it equals the config directory.  Empty/absent means
# "same as config" — preserving the historical single-directory behaviour.
data_dir_arg="${9:-}"

# cli_mode selects the command-line dialect:
#   v1     - Syncthing v1.2.2: historical single-dash CLI, no subcommands.
#   modern - standard binary and v1.27.12: `serve`/`generate` subcommands.
case "$legacy_version" in
    v1.2.2) cli_mode="v1" ;;
    *)      cli_mode="modern" ;;
esac

if [ -z "$home_dir" ] || [ -z "$port" ] || [ -z "$KOREADER_DIR" ]; then
    echo "Empty argument: home_dir='$home_dir' port='$port' koreader_dir='$KOREADER_DIR'" >&2
    exit 2
fi

export HOME="$home_dir"

config_dir="$KOREADER_DIR/settings/$config_dirname"
syncthing="$KOREADER_DIR/plugins/kosyncthing_plus.koplugin/$binary_name"
cacert="$KOREADER_DIR/plugins/kosyncthing_plus.koplugin/cacert.pem"

# The database directory.  Defaults to config_dir (historical behaviour) when
# arg 9 is empty.  On an affected Kindle, st_utils.getDataDir() passes a
# persistent ext path here so the SQLite DB and its WAL/SHM live off the
# hard_remove FUSE mount.  TMPDIR/SQLITE_TMPDIR are pointed at the same place
# ONLY when we actually relocate, because SQLite's DELETE-ON-CLOSE temp files
# (VACUUM, large sorts) follow TMPDIR, not --data, and must not land on the
# broken mount.  When we do NOT relocate (healthy device, or legacy/LevelDB
# which is unaffected) we leave TMPDIR untouched so behaviour is identical to
# before — temp files use the system default (tmpfs), not the FUSE mount.
data_dir="${data_dir_arg:-$config_dir}"
[ -z "$data_dir" ] && data_dir="$config_dir"
if [ "$data_dir" != "$config_dir" ]; then
    if mkdir -p "$data_dir" 2>/dev/null; then
        export TMPDIR="$data_dir"
        export SQLITE_TMPDIR="$data_dir"
    else
        echo "Cannot create data dir: $data_dir — falling back to config dir." >&2
        data_dir="$config_dir"
        # No TMPDIR override on fallback: use the system default temp location.
    fi
fi

export SSL_CERT_FILE="$cacert"

# ---------------------------------------------------------------------------
# Sanity checks
# ---------------------------------------------------------------------------
if [ ! -d "$home_dir" ]; then
    echo "Home directory does not exist: $home_dir" >&2
    exit 1
fi

if [ ! -x "$syncthing" ]; then
    echo "Syncthing binary not found or not executable: $syncthing" >&2
    exit 1
fi

# Port must be a plain integer in the valid range.
case "$port" in
    ''|*[!0-9]*) echo "Invalid port format: $port" >&2; exit 1 ;;
esac
if [ "$port" -lt 1024 ] || [ "$port" -gt 65535 ]; then
    echo "Port out of range (must be 1024-65535): $port" >&2
    exit 1
fi

case "$resource" in
    low|normal) ;;
    *) echo "Invalid resource profile: $resource (expected 'low' or 'normal')" >&2; exit 1 ;;
esac
case "$network" in
    lan|global) ;;
    *) echo "Invalid network mode: $network (expected 'lan' or 'global')" >&2; exit 1 ;;
esac

# ---------------------------------------------------------------------------
# Double-start guard
# ---------------------------------------------------------------------------
if [ -s "$pid_file" ]; then
    old_pid=$(cat "$pid_file" 2>/dev/null)
    if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
        if [ -r "/proc/$old_pid/comm" ]; then
            comm=$(cat "/proc/$old_pid/comm" 2>/dev/null)
            case "$comm" in
                syncthing*)
                    echo "Syncthing already running with PID $old_pid." >&2
                    written_pid="yes" # pid_file belongs to the already-running daemon, not us
                    exit 0
                    ;;
            esac
        else
            # /proc/comm not readable — we cannot verify the name,
            # but blocking startup is worse.  The Lua-side double-start
            # guard will handle a genuine duplicate.
            echo "Cannot verify PID $old_pid; proceeding with startup." >&2
            # fall through — do not exit
        fi
    fi
fi

mkdir -p "$config_dir" || { echo "Cannot create config dir: $config_dir" >&2; exit 1; }

# ---------------------------------------------------------------------------
# First-run config generation.
#
# modern (standard / v1.27.12):
#   The `generate` subcommand exists.  Syncthing introduced --no-port-probing
#   and --no-default-folder at different versions, so we try the most
#   featureful invocation first and degrade gracefully.
#
# v1 (v1.2.2):
#   Predates the `generate` subcommand and the --config/--data split.  The
#   historical CLI is `syncthing -generate=<dir>`, which creates cert.pem,
#   key.pem and config.xml in <dir> and then exits.  --no-port-probing does
#   not exist on this release; v1.2.2 does not probe ports during generate.
# ---------------------------------------------------------------------------
if [ ! -f "$config_dir/config.xml" ]; then
    echo "Generating Syncthing configuration..." >&2
    if [ "$cli_mode" = "v1" ]; then
        if ! "$syncthing" -generate="$config_dir" 2>/dev/null; then
            echo "Failed to generate Syncthing config (legacy v1.2.2)." >&2
            exit 1
        fi
    else
        # Attempt 1: modern flags — Syncthing v1.19.0+
        if ! "$syncthing" generate \
                --config="$config_dir" \
                --data="$data_dir" \
                --no-port-probing \
                --no-default-folder 2>/dev/null; then
            # Attempt 2: without --no-default-folder — Syncthing v1.12.0+
            if ! "$syncthing" generate \
                    --config="$config_dir" \
                    --data="$data_dir" \
                    --no-port-probing 2>/dev/null; then
                # Attempt 3: bare minimum — older v1.x without these flags.
                # A default folder will be created in config.xml; the user can
                # remove it via the Web GUI.  Port probing is harmless here
                # because we override the GUI address with --gui-address anyway.
                if ! "$syncthing" generate \
                        --config="$config_dir" \
                        --data="$data_dir" 2>/dev/null; then
                    echo "Failed to generate Syncthing config." >&2
                    exit 1
                fi
            fi
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Cache the device ID.
# modern: the `device-id` subcommand prints the ID authoritatively.
# v1    : v1.2.2 has no `device-id` subcommand.  Caching is skipped here;
#         the plugin reads the ID from the REST API (/rest/system/status
#         -> myID) on first need and writes the cache file itself.  This
#         step is non-fatal in every mode, so skipping it is safe.
# ---------------------------------------------------------------------------
if [ "$cli_mode" != "v1" ] && [ ! -s "$config_dir/device-id" ]; then
    device_id=$("$syncthing" device-id \
        --config="$config_dir" \
        --data="$data_dir" 2>/dev/null)
    if [ -n "$device_id" ]; then
        printf '%s\n' "$device_id" > "$config_dir/device-id" 2>/dev/null || \
            echo "Warning: could not cache device-id (non-fatal)." >&2
    else
        echo "Warning: could not read device-id for cache (non-fatal)." >&2
    fi
fi

# ---------------------------------------------------------------------------
# Go runtime tuning.
# GOMEMLIMIT, GOGC, and GOMAXPROCS are Go runtime environment variables —
# the correct mechanism for memory and concurrency control.
# Syncthing-specific tuning (maxFolderConcurrency, maxConcurrentIncomingRequestKiB,
# progressUpdateIntervalS) are config.xml <options> entries managed by the
# plugin via the REST API after startup; they are NOT CLI flags.
# ---------------------------------------------------------------------------
if [ "$resource" = "normal" ]; then
    export GOMEMLIMIT=134217728   # 128 MiB
    export GOGC=100
else
    export GOMEMLIMIT=67108864    # 64 MiB
    export GOGC=50
fi
export GOMAXPROCS=1               # single OS thread — appropriate for e-ink

# ---------------------------------------------------------------------------
# Network mode.
# --no-upgrade is the only network-related flag accepted by `syncthing serve`.
# STNOUPGRADE=1 is the documented env-variable equivalent.
# All other network settings (relay, NAT, global discovery, usage reporting)
# live in config.xml and are managed by the plugin via the Syncthing REST API.
# ---------------------------------------------------------------------------
if [ "$network" = "lan" ]; then
    export STNOUPGRADE=1
fi

# ---------------------------------------------------------------------------
# Build the argument list without unquoted variable expansion.
# Using `set --` is the POSIX-safe way to build a dynamic argument list
# in /bin/sh where arrays are unavailable.
#
# modern (standard / v1.27.12): `serve` subcommand, --config/--data split,
#         --log-file with rotation, http:// GUI address URL.
# v1     (v1.2.2): historical single-dash CLI — no `serve` subcommand, no
#         --config/--data (only -home), -logfile instead of --log-file (no
#         rotation flags on this release), and -gui-address takes a bare
#         host:port without a URL scheme.  --no-upgrade still applies for
#         LAN mode.  These flags have been stable since the Syncthing 0.14
#         era and are the correct shape for v1.2.2.
# ---------------------------------------------------------------------------
if [ "$cli_mode" = "v1" ]; then
    set -- "$syncthing" \
        -home="$config_dir" \
        -gui-address="0.0.0.0:$port" \
        -logfile="$config_dir/syncthing.log" \
        -no-browser \
        -no-restart

    [ "$network" = "lan" ] && set -- "$@" -no-upgrade
else
    set -- "$syncthing" serve \
        --config="$config_dir" \
        --data="$data_dir" \
        --gui-address="http://0.0.0.0:$port" \
        --log-file="$config_dir/syncthing.log" \
        --log-max-size=5242880 \
        --log-max-old-files=1 \
        --no-browser

    [ "$network" = "lan" ] && set -- "$@" --no-upgrade
fi

# ---------------------------------------------------------------------------
# Launch
#
# setsid creates a new process session, detaching Syncthing from KOReader's
# session entirely.  On PocketBook (InkView) this prevents the OS from
# delivering SIGHUP to Syncthing when the session leader exits or when
# InkView cycles the process group on suspend/resume.
#
# setsid is NOT present in every busybox build (notably some Kindle firmwares
# omit it), so we probe for it first and fall back to a plain background
# launch.  The PID written to the pid_file is the Syncthing PID in both
# cases: exec() preserves PIDs through the setsid → nice → syncthing chain,
# and kill() in st_process.lua targets the PID directly (not the group).
# ---------------------------------------------------------------------------
if command -v setsid >/dev/null 2>&1; then
    setsid nice -n 10 "$@" &
else
    nice -n 10 "$@" &
fi
PID=$!

# Poll for up to 10 seconds.  A single `sleep 1` is not enough on slow
# e-ink devices where Syncthing can take several seconds to initialise.
i=0
while [ "$i" -lt 10 ]; do
    kill -0 "$PID" 2>/dev/null && break
    sleep 1
    i=$((i + 1))
done

if ! kill -0 "$PID" 2>/dev/null; then
    echo "Syncthing crashed during startup (PID $PID exited within 10 s)." >&2
    exit 1
fi

written_pid="yes"
printf '%s\n' "$PID" > "$pid_file"

exit 0
